# ── Dev Environment Variables ─────────────────────────────────
# Copy this to terraform.tfvars (never commit terraform.tfvars)

environment        = "dev"
location           = "eastus"
project_name       = "sentinel"
owner              = "ApepC"
allowed_admin_cidr = "YOUR_IP/32"   # Replace with your IP: curl ifconfig.me
deploy_vm          = false
admin_username     = "azureadmin"

vnet_address_space = "10.0.0.0/16"

subnets = {
  "snet-frontend"      = "10.0.1.0/24"
  "snet-backend"       = "10.0.2.0/24"
  "snet-data"          = "10.0.3.0/24"
  "snet-management"    = "10.0.4.0/24"
  "AzureBastionSubnet" = "10.0.5.0/26"
}

tags = {
  cost_center = "personal-lab"
}
